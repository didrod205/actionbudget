{
  "name": "actionbudget",
  "version": "0.1.0",
  "description": "Lint GitHub Actions workflows for CI-minute waste — missing dependency caching, no concurrency cancellation, no job timeouts, oversized matrices, duplicate push+pull_request runs, and costly macOS/Windows runners. Deterministic CLI, JSON/Markdown reports, no API key.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "actionbudget": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "example": "node dist/cli.js scan examples/.github/workflows",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "github-actions",
    "ci",
    "ci-cd",
    "actions",
    "workflow",
    "cost-optimization",
    "ci-minutes",
    "concurrency",
    "cache",
    "matrix",
    "devops",
    "linter",
    "yaml",
    "cli"
  ],
  "author": "didrod205 (https://github.com/didrod205)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/didrod205/actionbudget.git"
  },
  "bugs": {
    "url": "https://github.com/didrod205/actionbudget/issues"
  },
  "homepage": "https://github.com/didrod205/actionbudget#readme",
  "dependencies": {
    "cac": "^6.7.14",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
